<!-- Insertion des partials -->
<%- include('./partials/header')%>
                      
  <!-- Boucle pour lister les articles sur la page -->
  <% for(article of articles) {%>

  <article class="card pure-u-1 pure-u-lg-1-2 pure-u-xl-1-3">
    <header>
      <img class="card-img pure-img" src="images/<%= article.img %>" alt="<%= article.img_alt %>">
        <h2><%= article.title%></h2>
          <div class="card-meta">
            Technologies utilisées :
            <% for (let i = 0; i < article.category.length; i++) {%>
              <a href="/category/<%=article.category[i]%>"><%= article.category[i]%></a>
              <% } %>
          </div>
    </header>
    <p>

     <!-- Split "découpe" le text; slice récupère mes 30 premiers; join "recolle" le tout -->
    <% const resume = article.text.split(' ').slice(0, 30).join(' '); %>
    <%=`${resume} ...`%></p>

      <a class="card-action pure-button" href="/article/<%= article.title %>">Lire l'article</a>
  </article>
  <% } %>



<%- include('./partials/footer')%>